# =====================================
# FRONTEND - Variáveis de Ambiente React
# =====================================
# IMPORTANTE: Copie este arquivo para .env e preencha com seus valores
# O arquivo .env NÃO deve ser commitado no Git

# Supabase - Autenticação
REACT_APP_SUPABASE_URL=https://seu-projeto.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui

# Backend API
REACT_APP_API_URL=http://localhost:5000

# Ambiente
REACT_APP_ENV=development
