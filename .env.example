# =============================================================
# VARIÁVEIS DE AMBIENTE - FRONTEND (React / Vercel)
# =============================================================
# Copie este arquivo para .env e preencha os valores
# No Vercel: adicione-as em Project Settings > Environment Variables

# URL do backend (Railway, Render, ngrok, etc.)
# Ex: https://meu-backend.up.railway.app
REACT_APP_API_URL=https://SEU-BACKEND-URL-AQUI

# Supabase
REACT_APP_SUPABASE_URL=https://XXXXX.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJ...
REACT_APP_SUPABASE_SERVICE_KEY=eyJ...
