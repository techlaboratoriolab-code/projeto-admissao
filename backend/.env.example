# Exemplo de Arquivo .env
# Copie este arquivo para backend/.env e preencha com suas credenciais

# =====================================
# SUPABASE - Autenticação e Banco
# =====================================
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-anon-publica
SUPABASE_SERVICE_KEY=sua-service-role-key

# =====================================
# BANCO DE DADOS - apLIS (MySQL)
# =====================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_NAME=aplis

# =====================================
# AWS S3 - Armazenamento de Documentos (OPCIONAL)
# =====================================
# Necessário apenas se for usar upload de documentos
AWS_ACCESS_KEY_ID=sua-access-key-id
AWS_SECRET_ACCESS_KEY=sua-secret-access-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=seu-bucket

# =====================================
# GOOGLE CLOUD - Vertex AI para OCR (OPCIONAL)
# =====================================
# Necessário apenas se for usar OCR de documentos
GOOGLE_PROJECT_ID=seu-projeto-gcp
GOOGLE_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=backend/credenciais-gcp.json

# =====================================
# API apLIS - Integração WebService
# =====================================
APLIS_BASE_URL=http://192.168.1.100:8080
APLIS_USUARIO=usuario-api
APLIS_SENHA=senha-api

# =====================================
# HUB DO DESENVOLVEDOR - Consulta CPF
# =====================================
HUB_DEV_BASE_URL=https://ws.hubdodesenvolvedor.com.br/v2/cpf/
HUB_DEV_TOKEN=seu-token-aqui

# =====================================
# SENHA PADRÃO DO ADMIN (Altere imediatamente após criar)
# =====================================
ADMIN_DEFAULT_PASSWORD=Admin@123!Change

# =====================================
# CONFIGURAÇÕES DA API FLASK
# =====================================
PORT=5000
FLASK_ENV=development
FLASK_DEBUG=True

# =====================================
# CONFIGURAÇÕES DE RATE LIMITING
# =====================================
# Requisições por minuto para APIs externas
MAX_REQUESTS_PER_MINUTE=10
MIN_DELAY_SECONDS=6

# =====================================
# CONFIGURAÇÕES DE CACHE
# =====================================
# Tempo de cache em segundos
CACHE_TIMEOUT=3600

# =====================================
# LOGS
# =====================================
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
