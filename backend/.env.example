# Configurações do Banco de Dados (Legado - não mais usado)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=newdb

# Configurações AWS S3
AWS_ACCESS_KEY_ID=sua_access_key_aqui
AWS_SECRET_ACCESS_KEY=sua_secret_key_aqui
AWS_REGION=sa-east-1
S3_BUCKET_NAME=aplis2

# Configurações Google Cloud (Vertex AI para OCR)
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/seu-arquivo-credentials.json
GOOGLE_LOCATION=us-central1

# URL base da API (deixe vazio para usar automaticamente)
API_BASE_URL=
